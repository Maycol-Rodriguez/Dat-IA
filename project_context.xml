                                "deliveries (...);"
                            ),
                        }
                    ],
                }

            return {
                "ids": [],
                "documents": [],
                "metadatas": [],
            }

    class FakeCollection:
        def __init__(self) -> None:
            self._collection = (
                FakeRawCollection()
            )

