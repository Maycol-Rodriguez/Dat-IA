      "group_by": [
        "month"
      ],
      "context": [
        "ventas"
      ],
      "sql": "SELECT DATE_TRUNC('month', sale_date) AS month, SUM(revenue) AS total_revenue FROM sales WHERE state = 'SP' AND sale_date >= '2018-01-01' AND sale_date < '2019-01-01' GROUP BY 1 ORDER BY 1;",
      "sources": "sales",
      "validated": true,
      "execution_status": "success",
      "operation": "sum"
