      "key": "sales_monthly_total_sp",
      "original_question": "¿Cuál fue la facturación total mensual en São Paulo durante 2018?",
      "normalized_question": "Calcular la suma mensual de ingresos por ventas en São Paulo durante 2018.",
      "intent": "temporal_trend",
      "metrics": [
        "revenue"
      ],
      "filters": [
        {
          "field": "state",
          "operator": "=",
          "value": "SP"
        }
      ],
      "date_range": {
        "start": "2018-01-01",
        "end": "2018-12-31"
